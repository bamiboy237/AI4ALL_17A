{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm ci && npm run build",
  "functions": {
    "api/index.py": {
      "includeFiles": "{ham10000_cnn_improved.keras,ddi_cnn_improved.keras,frontend/build/**}",
      "excludeFiles": "{frontend/node_modules/**,frontend/src/**,frontend/public/**,ham_ann_baseline.keras,backend/tests/**}"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
